{
  "name": "bellwether-servicing-portal",
  "version": "1.0.0",
  "description": "Bellwether Servicing Portal — loan portfolio management desktop app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:portable": "electron-builder --win portable",
    "build:installer": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.bellwetheram.servicing-portal",
    "productName": "Bellwether Servicing Portal",
    "copyright": "Copyright © 2025 Bellwether Asset Management, Inc.",
    "files": [
      "main.js",
      "app.html"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Bellwether Servicing Portal",
      "installerHeaderIcon": "assets/icon.ico"
    }
  }
}
